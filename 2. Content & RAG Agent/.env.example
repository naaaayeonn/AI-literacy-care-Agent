# Gemini / SnowChat API Key (sookmyung.factchat.bot / factchat-cloud.mindlogic.ai)
GEMINI_API_KEY=your_snowchat_api_key_here

# 국립국어원 우리말샘 오픈 API 키 (공공데이터포털)
WOORIMAL_API_KEY=your_woorimal_api_key_here

# 모드 설정: "real" = 실제 Claude API, "stub" = 더미 반환
CONTENT_REDUCER_MODE=real

# 난이도 임계값 (이 값 이상이면 Claude Sonnet, 미만이면 Haiku 사용)
DIFFICULTY_THRESHOLD_FOR_HEAVY_LLM=55

# RAG 모드: "memory" = JSON 파일 기반 인메모리 (기본), "pgvector" = PostgreSQL
RAG_MODE=memory

# 임베딩 모델 (sentence-transformers)
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask

# Faithfulness 임계값 (이 점수 미만이면 trace에 경고 기록)
FAITHFULNESS_THRESHOLD=0.80

# 데모 모드 (true이면 API 없이 샘플 데이터 반환)
DEMO_MODE=false

# pgvector 설정 (RAG_MODE=pgvector 사용 시에만 필요)
# PGVECTOR_HOST=localhost
# PGVECTOR_PORT=5432
# PGVECTOR_DB=literacy_care
# PGVECTOR_USER=postgres
# PGVECTOR_PASSWORD=your_password
